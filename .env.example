# Ultimate RAG - Environment Variables

# ===== SurrealDB =====
# Local: http://localhost:8000
# Cloud: https://your-instance.surreal.cloud
SURREALDB_URL=http://localhost:8000
SURREALDB_USER=root
SURREALDB_PASSWORD=root
SURREALDB_NS=ultrarag
SURREALDB_DB=ultrarag

# ===== LLM =====
LLM_PROVIDER=ollama  # openai, anthropic, ollama, gemini
LLM_MODEL=llama3.2
LLM_API_KEY=
LLM_BASE_URL=http://localhost:11434

# ===== Embeddings =====
EMBED_PROVIDER=ollama  # ollama, openai
EMBED_MODEL=nomic-embed-text

# ===== App =====
APP_HOST=0.0.0.0
APP_PORT=8001