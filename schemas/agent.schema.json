{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agennext.org/schemas/agent.schema.json",
  "title": "Agent",
  "type": "object",
  "required": ["id", "name", "mission", "runtime", "governance", "trust"],
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string" },
    "mission": { "type": "string" },
    "description": { "type": "string" },
    "runtime": { "type": "string" },
    "book": { "type": "string" },
    "tools": { "type": "array", "items": { "type": "string" } },
    "memory": { "type": "array", "items": { "type": "string" } },
    "governance": { "type": "string" },
    "trust": { "type": "number", "minimum": 0, "maximum": 100 },
    "lifecycle_state": {
      "type": "string",
      "enum": ["draft", "review", "approved", "active", "probation", "suspended", "retired", "archived"]
    }
  },
  "additionalProperties": false
}
