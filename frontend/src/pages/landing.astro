<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Ultimate RAG - Next-Gen AI Knowledge Platform</title>
  <meta name="description" content="Ultimate RAG: SurrealDB + LightRAG + RAGFlow. All-in-one RAG with vector, graph, and full-text search." />
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <style>
    body { font-family: 'Inter', sans-serif; }
    .gradient-text {
      background: linear-gradient(135deg, #3b82f6, #8b5cf6);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }
    .glow {
      box-shadow: 0 0 60px rgba(139, 92, 246, 0.3);
    }
    .card:hover {
      transform: translateY(-4px);
    }
  </style>
</head>
<body class="bg-gray-950 text-white">
  <!-- Nav -->
  <nav class="fixed top-0 w-full z-50 border-b border-white/10 bg-gray-950/80 backdrop-blur">
    <div class="max-w-6xl mx-auto px-6 py-4 flex justify-between items-center">
      <div class="flex items-center gap-2">
        <span class="text-2xl">🧠</span>
        <span class="text-xl font-bold">Ultimate RAG</span>
      </div>
      <div class="flex gap-6 text-sm">
        <a href="#features" class="text-gray-400 hover:text-white transition">Features</a>
        <a href="#architecture" class="text-gray-400 hover:text-white transition">Architecture</a>
        <a href="#docs" class="text-gray-400 hover:text-white transition">Docs</a>
        <a href="https://github.com/AGenNext/Agent-Book" class="text-gray-400 hover:text-white transition">GitHub</a>
      </div>
    </div>
  </nav>

  <!-- Hero -->
  <section class="pt-32 pb-20 text-center">
    <div class="max-w-4xl mx-auto px-6">
      <div class="inline-block px-4 py-1 rounded-full border border-blue-500/30 bg-blue-500/10 text-blue-400 text-sm mb-6">
        🚀 Open Source • SurrealDB Powered
      </div>
      <h1 class="text-5xl md:text-7xl font-bold mb-6">
        <span class="gradient-text">Ultimate RAG</span>
      </h1>
      <p class="text-xl text-gray-400 mb-8 max-w-2xl mx-auto">
        All-in-one RAG platform combining SurrealDB's HNSW vectors, knowledge graphs, 
        and full-text search. Inspired by LightRAG, RAGFlow, and Glean.
      </p>
      <div class="flex gap-4 justify-center">
        <a href="#try" class="px-8 py-3 bg-gradient-to-r from-blue-600 to-purple-600 rounded-lg font-medium hover:opacity-90 transition">
          Get Started →
        </a>
        <a href="https://github.com/AGenNext/Agent-Book" class="px-8 py-3 border border-white/20 rounded-lg font-medium hover:bg-white/10 transition">
          GitHub ⭐
        </a>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section id="features" class="py-20 border-t border-white/10">
    <div class="max-w-6xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-center mb-12">Why Ultimate RAG?</h2>
      <div class="grid md:grid-cols-3 gap-6">
        <!-- Feature 1 -->
        <div class="card p-6 rounded-xl border border-white/10 bg-white/5 transition-all duration-300">
          <div class="text-3xl mb-4">📊</div>
          <h3 class="text-xl font-semibold mb-2">HNSW Vectors</h3>
          <p class="text-gray-400 text-sm">Native SurrealDB vector indexing with HNSW for fast similarity search.</p>
        </div>
        <!-- Feature 2 -->
        <div class="card p-6 rounded-xl border border-white/10 bg-white/5 transition-all duration-300">
          <div class="text-3xl mb-4">🕸️</div>
          <h3 class="text-xl font-semibold mb-2">Knowledge Graph</h3>
          <p class="text-gray-400 text-sm">Entity-relation graph for multi-hop reasoning.</p>
        </div>
        <!-- Feature 3 -->
        <div class="card p-6 rounded-xl border border-white/10 bg-white/5 transition-all duration-300">
          <div class="text-3xl mb-4">🔍</div>
          <h3 class="text-xl font-semibold mb-2">Hybrid Search</h3>
          <p class="text-gray-400 text-sm">Vector + graph + full-text fusion for best results.</p>
        </div>
        <!-- Feature 4 -->
        <div class="card p-6 rounded-xl border border-white/10 bg-white/5 transition-all duration-300">
          <div class="text-3xl mb-4">📄</div>
          <h3 class="text-xl font-semibold mb-2">Multimodal ETL</h3>
          <p class="text-gray-400 text-sm">PDF, images, audio, video processing.</p>
        </div>
        <!-- Feature 5 -->
        <div class="card p-6 rounded-xl border border-white/10 bg-white/5 transition-all duration-300">
          <div class="text-3xl mb-4">⚡</div>
          <h3 class="text-xl font-semibold mb-2">FastAPI + WebSocket</h3>
          <p class="text-gray-400 text-sm">REST API with real-time streaming.</p>
        </div>
        <!-- Feature 6 -->
        <div class="card p-6 rounded-xl border border-white/10 bg-white/5 transition-all duration-300">
          <div class="text-3xl mb-4">🐳</div>
          <h3 class="text-xl font-semibold mb-2">Docker Ready</h3>
          <p class="text-gray-400 text-sm">One-command deployment.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Architecture -->
  <section id="architecture" class="py-20 border-t border-white/10 bg-gray-900/50">
    <div class="max-w-4xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-center mb-4">Architecture</h2>
      <p class="text-gray-400 text-center mb-12">SurrealDB as unified backend</p>
      <div class="bg-gray-900 rounded-xl border border-white/10 p-6 overflow-x-auto">
        <pre class="text-sm text-gray-300">
┌─────────────────────────────────────────┐
│         Frontend (Astro)                 │
│   Chat • Graph • Search • Documents     │
└─────────────────┬───────────────────────┘
                  │ HTTP
┌─────────────────▼───────────────────────┐
│         Backend (FastAPI)                │
│   /query • /index • /ws/chat • /graph  │
└─────────────────┬───────────────────────┘
                  │
┌─────────────────▼───────────────────────┐
│         SurrealDB (mem://)              │
│   • chunk (HNSW vectors)               │
│   • entity (graph nodes)                │
│   • relation (edges)                  │
│   • document (full-text)               │
│   • chat (history)                   │
└─────────────────────────────────────┘
        </pre>
      </div>
    </div>
  </section>

  <!-- Code -->
  <section id="try" class="py-20 border-t border-white/10">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h2 class="text-3xl font-bold mb-8">Quick Start</h2>
      <div class="text-left max-w-lg mx-auto">
        <div class="bg-gray-900 rounded-xl border border-white/10 p-4 font-mono text-sm">
          <div class="text-gray-400"># Clone</div>
          <div class="text-green-400 mb-4">git clone https://github.com/AGenNext/Agent-Book.git</div>
          
          <div class="text-gray-400"># Install</div>
          <div class="text-green-400 mb-4">pip install -r requirements.txt</div>
          
          <div class="text-gray-400"># Run (embedded DB - no server!)</div>
          <div class="text-green-400 mb-4">python -m backend.main</div>
          
          <div class="text-gray-400"># Or with Docker</div>
          <div class="text-green-400">docker build -t ultrarag . && docker run -p 8001:8001 ultrarag</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="py-12 border-t border-white/10 text-center">
    <div class="max-w-6xl mx-auto px-6">
      <div class="flex justify-center gap-2 mb-4">
        <span class="text-2xl">🧠</span>
        <span class="text-xl font-bold">Ultimate RAG</span>
      </div>
      <p class="text-gray-500 text-sm">
        Built with SurrealDB • Inspired by LightRAG, RAGFlow, RAG-Anything, Glean, Onyx
      </p>
      <p class="text-gray-600 text-xs mt-4">
        <a href="https://github.com/AGenNext/Agent-Book">AGenNext/Agent-Book</a>
      </p>
    </div>
  </footer>
</body>
</html>